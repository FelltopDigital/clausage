# ──────────────────────────────────────────────────────────────────────────
# clausage environment. Copy to apps/web/.env.local for local dev.
# Every var the app reads is listed here. See SETUP.md for where to get each.
# ──────────────────────────────────────────────────────────────────────────

# Postgres (Neon). Use the POOLED connection string in production.
# Local dev example: postgres://postgres:postgres@localhost:5432/clausage
DATABASE_URL=

# Public base URL of the app (no trailing slash).
APP_URL=http://localhost:3000

# Secret used to sign session cookies. Generate: openssl rand -hex 32
AUTH_SECRET=dev-insecure-secret-change-me

# Resend — transactional email for magic links. https://resend.com
# If unset, magic links are logged to the server console (dev fallback).
RESEND_API_KEY=
EMAIL_FROM=clausage <login@clausage.com>

# Stripe — one-time $2.99 purchase to make a page public.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ── CLI (optional overrides; normally not needed) ──────────────────────────
# CLAUSAGE_API_URL=https://clausage.com
# CLAUSAGE_TOKEN=clst_...
# CLAUSAGE_LOGS_DIR=~/.claude/projects
