{
  "name": "clausage-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "clausage — Claude Code usage grid, shareable in your bio.",
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @clausage/web dev",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "test": "pnpm --filter @clausage/shared test",
    "db:generate": "pnpm --filter @clausage/web db:generate",
    "db:migrate": "pnpm --filter @clausage/web db:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
